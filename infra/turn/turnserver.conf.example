listening-port=3478
tls-listening-port=5349
realm=robocop.local
server-name=robocop-turn

fingerprint
lt-cred-mech
use-auth-secret
static-auth-secret=CHANGE_ME_LONG_RANDOM_SECRET

no-multicast-peers
no-cli
no-tlsv1
no-tlsv1_1

min-port=49160
max-port=49200

# Set these on real deployments behind NAT:
# external-ip=PUBLIC_IP/PRIVATE_IP

# Add certs for turns:5349:
# cert=/etc/coturn/certs/fullchain.pem
# pkey=/etc/coturn/certs/privkey.pem

log-file=stdout
simple-log
